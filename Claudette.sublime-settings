{
	// API key configuration. You can define a single key or multiple keys.
	//
	// Example for a single key:
	//
	// api_key: "your-key-here"
	//
	// Example for multiple keys:
	//
	// api_key: {
	//     "keys": [
	//         {
	//             name: "Work",
	//             key: "your-key-here"
	//         },
	//         {
	//             name: "Private",
	//             key: "your-key-here"
	//         },
	//     ],
	//     "active_key": 0
	// }
	//
	// https://console.anthropic.com/settings/keys
	//
	"api_key": "",
	// API base URL. Use the default for Anthropic, or set to a third-party
	// Anthropic-compatible endpoint (e.g. https://api.deepseek.com/anthropic/).
	"base_url": "https://api.anthropic.com/v1/",
	// SSL certificate verification. Set to false to allow self-signed certificates
	// (useful for custom base_url with development servers). Defaults to true.
	// WARNING: Disabling SSL verification reduces security and should only be
	// used in trusted development environments.
	"verify_ssl": true,
	// Optional: custom headers to include in all API requests.
	// Format: {"Header-Name": "header-value", "Another-Header": "another-value"}
	"custom_headers": {},
	// Maximum number of output tokens per response. Must not exceed the
	// selected model's output limit. The API will return a 400 error if this
	// value exceeds the model's maximum. Common limits:
	//   - Claude Opus 4.6: 128,000
	//   - Claude Sonnet 4.5 / Haiku 4.5: 64,000
	//   - Claude Sonnet 4 / Opus 4: 8,192
	"max_tokens": 8192,
	// Note that a 'Switch Model' command exists that allows you to select the
	// model via the command palette.
	//
	// https://docs.anthropic.com/en/docs/about-claude/models#model-comparison-table
	"model": "claude-sonnet-4-5",
	// The system message is added when the first request is sent to the
	// API. If an empty system message is selected as the
	// default_system_message_index, no system message will be sent.
	"system_messages": [
		"You are a helpful AI assistant focused on programming help.",
		"You are a helpful AI assistant focused on writing and documentation.",
		"You are a helpful AI assistant ready to help with any task.",
	],
	// Index of the currently active system message in the system_messages setting.
	"default_system_message_index": 0,
	"temperature": "1.0",
	// When true, Claude can search the web for up-to-date information. Only works
	// with supported models (e.g. Claude Opus 4.6, 4.5, Sonnet 4.5, Haiku 4.5).
	// Web search is billed at $10 per 1,000 searches in addition to token costs.
	// https://platform.claude.com/docs/en/agents-and-tools/tool-use/web-search-tool
	"web_search": false,
	// When true, Claude can view and edit files (view, str_replace, create, insert)
	// in your project. Uses non-streaming requests until the turn ends.
	// Paths are resolved against project folders or text_editor_tool_roots.
	// Only available with the Anthropic API provider.
	// https://platform.claude.com/docs/en/agents-and-tools/tool-use/text-editor-tool
	"text_editor_tool": false,
	// Optional: max characters when viewing a file (Claude 4 tool only). 0 = no limit.
	// "text_editor_tool_max_characters": 10000,
	// Optional: extra allowed roots for file operations (paths must be under these or project folders).
	"text_editor_tool_roots": [],
	// Maximum number of web searches per request when web_search is enabled (1–20).
	"web_search_max_uses": 5,
	// Optional: only include results from these domains (e.g. ["example.com", "docs.example.com"]).
	// Do not set both web_search_allowed_domains and web_search_blocked_domains.
	"web_search_allowed_domains": [],
	// Optional: exclude results from these domains.
	"web_search_blocked_domains": [],
	// Optional: localize search results. IANA timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
	// "web_search_user_location": {
	//     "type": "approximate",
	//     "city": "San Francisco",
	//     "region": "California",
	//     "country": "US",
	//     "timezone": "America/Los_Angeles"
	// },
	// Pricing per 1M tokens (USD). Tier keys are matched as substrings of the
	// model name (case-insensitive). Add entries for any model you use.
	// https://www.anthropic.com/pricing#702702
	"pricing": {
		"haiku": {
			"input": 1,
			"output": 5,
			"cache_write": 1.25,
			"cache_read": 0.1
		},
		"opus": {
			"input": 5,
			"output": 25,
			"cache_write": 6.25,
			"cache_read": 0.5
		},
		"sonnet": {
			"input": 3,
			"output": 15,
			"cache_write": 3.75,
			"cache_read": 0.3
		},
		"deepseek-chat": {
			"input": 0.27,
			"output": 1.10
		},
		"deepseek-reasoner": {
			"input": 0.55,
			"output": 2.19
		}
	},
	"chat": {
		"line_numbers": false,
		"rulers": false,
		// If set_scratch is set to true, the chat view will be closed without
		// prompting to save.
		"set_scratch": true,
		// Show cost information after each response in the chat view
		"show_cost": true
	}
}
